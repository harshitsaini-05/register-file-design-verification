`timescale 1ns/1ps
module reg4bit(
input logic clk,
input logic we,
input logic [1:0] w_addr,
input logic [3:0] w_data,
input logic [1:0] r_addr1,
input logic [1:0] r_addr2,
output logic [3:0] r_data1,
output logic [3:0] r_data2
);
reg [3:0] mem [0:3];

always_ff @(posedge clk) begin
if(we)
mem[w_addr] <= w_data;
end
assign r_data1 = mem[r_addr1];
assign r_data2 = mem[r_addr2];

endmodule
